  <!-- === TECHNICAL CONTEXT === -->
  <technicalContext>
    <technicalObjective>
      建立完整的内存使用优化体系，包括内存监控、动态分配、算子优化、批处理管理、GC优化，
      确保在不影响转换质量的前提下，最大化内存使用效率。
    </technicalObjective>

    <architectureOverview>
      <layer name="Core Framework">
        <component>Epic 1基础架构</component>
        <description>62类，236函数，5704行核心代码，提供基础内存管理能力</description>
      </layer>

      <layer name="Conversion Layer">
        <component>Epic 2转换系统</component>
        <description>完整转换流程，支持多种模型转换，提供内存使用场景</description>
      </layer>

      <layer name="Performance Layer">
        <component>Story 3.1性能基础</component>
        <description>性能监控、分析、优化基础架构</description>
      </layer>

      <layer name="Memory Optimization">
        <component>Story 3.2内存优化</component>
        <description>当前故事：内存使用监控、优化策略、分析报告、泄漏检测</description>
      </layer>
    </architectureOverview>

    <keyComponents>
      <component name="MemoryMonitor">
        <purpose>实时监控内存使用情况</purpose>
        <responsibility>
          - 转换过程内存使用实时监控（当前值、峰值、平均值）
          - 模型结构内存占用分析
          - 批处理场景内存使用统计
          - 内存使用趋势分析和预警
        </responsibility>
      </component>

      <component name="MemoryStrategy">
        <purpose>内存优化策略实施</purpose>
        <responsibility>
          - 动态内存分配优化（内存池、对象复用）
          - 算子级内存优化（中间结果复用、内存压缩）
          - 批处理内存管理（队列管理、批大小调整）
          - GC优化策略（引用计数、循环检测）
        </responsibility>
      </component>

      <component name="MemoryAnalyzer">
        <purpose>内存使用分析和报告</purpose>
        <responsibility>
          - 内存使用模式和效率分析
          - 优化建议生成
          - 多格式报告生成（JSON/HTML/PDF）
          - 内存使用统计和趋势分析
        </responsibility>
      </component>

      <component name="MemoryLeakDetector">
        <purpose>内存泄漏检测和防护</purpose>
        <responsibility>
          - 内存泄漏自动检测
          - 内存越界检测
          - 内存使用异常监控
          - 内存问题诊断和修复建议
        </responsibility>
      </component>
    </keyComponents>

    <dataFlow>
      <step name="Memory Monitoring">
        <description>实时收集内存使用数据</description>
        <output>内存使用指标数据</output>
      </step>

      <step name="Memory Analysis">
        <description>分析内存使用模式和效率</description>
        <output>内存分析报告</output>
      </step>

      <step name="Memory Optimization">
        <description>应用内存优化策略</description>
        <output>优化后的内存使用</output>
      </step>

      <step name="Memory Validation">
        <description>验证优化效果和质量</description>
        <output>优化效果验证报告</output>
