<context id="story-3.2" title="内存使用优化">
  <!--
    Story Context for Story 3.2: 内存使用优化
    Generated: 2025-10-28
    Version: 1.0
    Status: Ready for Development

    Strategic Background:
    Story 3.2 is part of Epic 3: Performance Optimization and Extension.
    This story focuses on implementing comprehensive memory usage optimization
    for NPU model conversion, ensuring efficient memory utilization for
    large-scale model conversion and batch processing scenarios.
  -->

  <!-- === STORY METADATA === -->
  <metadata>
    <storyId>story-3.2</storyId>
