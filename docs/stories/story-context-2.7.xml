  <!-- ========================================
       1. 战略上下文 (Strategic Context)
       ======================================== -->
  <strategic_context>
    <business_objective>
      实现完整的模型精度验证系统，确保所有转换后的模型满足PRD质量标准（>98%精度）
    </business_objective>

    <strategic_position>
      <position_in_epic>Epic 2第7个故事，核心质量保证组件</position_in_epic>
      <value_proposition>
        为所有转换模型提供精度验证，增强用户信心，预防精度问题
      </value_proposition>
      <differentiation>
        基于Epic 2转换经验的统一验证框架，支持多维度精度分析
      </differentiation>
    </strategic_position>

    <alignment>
      <product_strategy>
        确保NPU转换工具产品质量，符合PRD质量标准
      </product_strategy>
      <epic_strategy>
        完成Epic 2模型转换功能的最后环节，提供质量保证
      </epic_strategy>
      <project_strategy>
        实现完整端到端模型转换+验证能力
      </project_strategy>
    </alignment>

    <key_results>
      <kr1>所有转换模型精度验证覆盖率 100%</kr1>
      <kr2>验证准确性 >99%（超越PRD >98%标准）</kr3>
      <kr3>5个Acceptance Criteria 100%完成</kr3>
      <kr4>BMM v6 Phase 1-4 100%完成</kr4>
    </key_results>
  </strategic_context>

  <!-- ========================================
       2. 业务上下文 (Business Context)
       ======================================== -->
  <business_context>
    <problem_statement>
      模型转换后如何确保精度不损失？如何验证转换模型的正确性？
    </problem_statement>

    <target_users>
      <primary_users>
        <user_type>AI模型工程师</user_type>
        <user_needs>
          验证模型转换质量，确保精度符合标准
        </user_needs>
      </primary_users>
      <secondary_users>
        <user_type>QA工程师</user_type>
        <user_needs>
          模型质量保证和合规验证
        </user_needs>
        <user_type>产品经理</user_type>
        <user_needs>
          产品交付质量保证
        </user_needs>
      </secondary_users>
    </target_users>

    <use_cases>
      <use_case id="UC1">
        <name>转换后模型精度验证</name>
        <description>验证VITS-Cantonese、SenseVoice等转换模型的精度</description>
        <actors>AI模型工程师</actors>
        <precondition>模型已完成转换</precondition>
        <main_flow>
          1. 导入转换后的模型
          2. 运行精度验证
          3. 查看验证报告
        </main_flow>
        <success_criteria>获得详细精度分析报告</success_criteria>
      </use_case>

      <use_case id="UC2">
        <name>批量模型精度监控</name>
        <description>监控多个模型的精度状态</description>
        <actors>QA工程师</actors>
        <precondition>有多个转换模型</precondition>
        <main_flow>
          1. 配置批量验证任务
          2. 运行批量验证
          3. 生成汇总报告
        </main_flow>
        <success_criteria>获得所有模型精度概览</success_criteria>
      </use_case>

      <use_case id="UC3">
        <name>精度阈值告警</name>
        <description>精度低于阈值时自动告警</description>
        <actors>系统</actors>
        <precondition>设置精度阈值</precondition>
        <main_flow>
          1. 检测到精度低于阈值
          2. 生成告警
          3. 提供修复建议
        </main_flow>
        <success_criteria>及时发现精度问题</success_criteria>
      </use_case>
    </use_cases>

    <business_value>
      <value_drivers>
        <driver>质量保证</driver>
        <description>确保所有转换模型满足PRD质量标准</description>
      </value_drivers>
      <value_drivers>
        <driver>风险预防</driver>
        <description>避免精度问题在生产环境中暴露</description>
      </value_drivers>
      <value_drivers>
        <driver>合规验证</driver>
        <description>满足产品交付质量要求</description>
      </value_drivers>
      <value_drivers>
        <driver>用户信心</driver>
        <description>增强用户对转换工具的信任</description>
      </value_drivers>
    </business_value>

    <success_metrics>
      <metric>
        <name>精度验证覆盖率</name>
        <target>100%</target>
        <measurement>所有转换模型都进行精度验证</measurement>
      </metric>
      <metric>
        <name>验证准确性</name>
        <target>>99%</target>
        <measurement>验证结果与实际精度对比</measurement>
      </metric>
      <metric>
        <name>问题发现率</name>
        <target>>95%</target>
        <measurement>精度问题检出率</measurement>
      </metric>
    </success_metrics>
  </business_context>

