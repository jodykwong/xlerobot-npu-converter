  <!-- === STRATEGIC CONTEXT === -->
  <strategicContext>
    <background>
      XLeRobot项目需要将AI模型转换为NPU可执行格式，以充分利用RDK X5硬件的10 TOPS算力。
      ASR（自动语音识别）模型是智能语音系统的核心组件，VITS-Cantonese TTS已完成（Story 2.2）。
      SenseVoice作为主要ASR模型，需要完整的NPU转换实现。
    </background>

    <problemStatement>
      SenseVoice作为主要ASR模型，当前只有基础转换流程（Story 1.5），缺乏生产级别的完整功能。
      多语言语音识别需要专门的优化和验证，确保转换后模型在NPU上高效、准确运行。
      转换成功率需要达到>95%，支持实时和批处理模式。
    </problemStatement>

    <solutionApproach>
      基于Story 1.5的基础转换流程，扩展为完整的生产级ASR转换系统，
      包含多语言专用优化、完整参数配置、精确验证和专用报告。
      确保转换成功率>95%，性能提升2-5倍，支持多种音频格式。
    </solutionApproach>

    <strategicAlignment>
      <primaryModel>SenseVoice ASR</primaryModel>
      <alternativeModels>VITS-Cantonese TTS, Piper VITS TTS</alternativeModels>
      <justification>
        PRD明确指定SenseVoice为主要ASR模型。这是语音识别功能的核心，
        与Story 2.2的VITS-Cantonese TTS形成完整的语音交互能力。
        主要模型优先获得完整功能实现，这是产品成功的关键。
      </justification>
    </strategicAlignment>

    <criticalSuccessFactors>
      <factor>多语言语音识别的精确处理和建模</factor>
      <factor>多种音频格式的支持和预处理优化</factor>
      <factor>实时流式识别和批处理模式的实现</factor>
      <factor>与Epic 1基础设施和Story 2.2的完美集成</factor>
    </criticalSuccessFactors>
  </strategicContext>

  <!-- === BUSINESS CONTEXT === -->
  <businessContext>
    <businessObjective>
      实现SenseVoice ASR模型的完整NPU转换流程，支持多语言语音识别在RDK X5硬件上的高效部署。
    </businessObjective>

    <businessValue>
      <value-proposition>
        为XLeRobot智能语音系统提供高性能的多语言语音识别能力，
        实现2-5倍的推理性能提升，降低计算成本，提升用户体验。
        与VITS-Cantonese TTS（Story 2.2）形成完整的语音交互闭环。
      </value-proposition>

      <targetUsers>
        <user type="AI模型工程师">
          需要将SenseVoice ASR模型部署到NPU硬件上，实现高效语音识别
        </user>
        <user type="语音系统开发者">
          寻求可靠的ASR模型转换工具，支持多语言识别
        </user>
        <user type="产品经理">
          需要可衡量的性能提升和转换成功率指标
        </user>
        <user type="智能助手开发者">
          需要端到端的语音交互解决方案（ASR + TTS）
        </user>
      </targetUsers>

      <keyMetrics>
        <metric name="转换成功率" target="&gt;95%" measurement="成功转换模型数/总转换尝试数"/>
        <metric name="性能提升倍数" target="2-5x" measurement="NPU推理速度/CPU推理速度"/>
        <metric name="识别准确率" target="&gt;95%" measurement="正确识别词数/总词数"/>
        <metric name="延迟" target="&lt;200ms" measurement="单次识别耗时"/>
        <metric name="代码覆盖率" target="&gt;90%" measurement="测试覆盖代码行数/总代码行数"/>
      </keyMetrics>

      <businessRisks>
        <risk level="High" description="多语言语音识别的复杂性可能导致准确率下降" mitigation="采用成熟算法，进行充分测试"/>
        <risk level="High" description="实时流式识别的性能要求严格" mitigation="优化算法，预分配资源"/>
        <risk level="Medium" description="多种音频格式支持的兼容性挑战" mitigation="标准化处理流程，充分测试"/>
        <risk level="Low" description="代码质量问题影响系统稳定性" mitigation="严格代码审查，测试驱动开发"/>
      </businessRisks>

      <competitiveAdvantage>
        <advantage>多语言支持的ASR转换能力</advantage>
        <advantage>实时和批处理模式双支持</advantage>
        <advantage>完整的NPU优化和验证体系</advantage>
        <advantage>与TTS模型形成完整语音交互方案</advantage>
      </competitiveAdvantage>
    </businessValue>
  </businessContext>

