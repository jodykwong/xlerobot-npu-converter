      </scenarios>
    </attribute>
  </qualityAttributes>

  <!-- === RISKS AND MITIGATION === -->
  <riskAssessment>
    <risk id="RISK-1" category="Technical" probability="Medium" impact="High">
      <title>粤语声调处理的复杂性</title>
      <description>
        粤语九声六调的精确建模和语音合成优化是一项复杂的任务，
        可能导致语音质量下降或转换失败。
      </description>
      <mitigation>
        <strategy>Research existing Cantonese TTS implementations and adopt proven algorithms</strategy>
        <actions>
          <action>研究现有的粤语TTS实现</action>
          <action>采用经过验证的声调建模算法</action>
          <action>建立全面的测试集验证声调准确性</action>
        </actions>
        <contingency>
          如果粤语优化复杂度过高，先实现基础转换，再逐步优化声调处理。
        </contingency>
      </mitigation>
    </risk>

    <risk id="RISK-2" category="Technical" probability="Medium" impact="High">
      <title>Horizon X5工具链适配</title>
      <description>
        BPU工具链对VITS-Cantonese模型的支持度未知，
        可能存在不兼容算子或转换失败。
      </description>
      <mitigation>
        <strategy>提前进行工具链兼容性测试</strategy>
        <actions>
          <action>在开发初期进行小规模兼容性测试</action>
          <action>建立备选转换方案（如果需要）</action>
          <action>与Horizon技术支持团队保持沟通</action>
        </actions>
        <contingency>
          如果工具链完全不兼容，探索其他NPU平台或纯CPU优化方案。
        </contingency>
      </mitigation>
    </risk>

    <risk id="RISK-3" category="Quality" probability="Low" impact="Medium">
      <title>代码质量和覆盖率</title>
      <description>
        复杂的功能可能导致代码质量问题或测试覆盖不足，
        影响系统稳定性和可维护性。
      </description>
      <mitigation>
        <strategy>严格代码审查和测试驱动开发</strategy>
        <actions>
          <action>每次提交前进行代码审查</action>
          <action>新功能必须同时编写测试</action>
          <action>持续集成中强制覆盖率检查</action>
        </actions>
        <contingency>
          如果时间有限，优先保证核心功能测试，辅助功能测试可延后。
        </contingency>
      </mitigation>
    </risk>
  </riskAssessment>

