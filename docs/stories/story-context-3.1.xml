  <!-- === STRATEGIC CONTEXT === -->
  <strategicContext>
    <background>
      XLeRobot项目已完成Epic 1（基础设施）和Epic 2（模型转换）的开发，
      建立了完整的NPU模型转换能力。为了满足企业级生产环境的需求，
      需要对系统进行全面的性能优化和扩展能力提升，确保高并发、高效率、高稳定性。
    </background>

    <problemStatement>
      当前系统虽然功能完整，但需要在生产环境中验证和优化性能。
      面临的主要挑战包括：转换延迟需要优化、并发处理能力需要增强、
      资源利用率需要提升、长时间运行的稳定性需要保证。
    </problemStatement>

    <solutionApproach>
      基于Epic 1和Epic 2的完整基础设施，实现性能分析框架、优化核心转换流程、
      构建可扩展的并发架构、优化资源使用、提供性能调优系统。
      确保转换时间<5分钟，支持10+模型并发转换，内存使用降低30%+。
    </solutionApproach>

    <strategicAlignment>
      <primaryFocus>性能优化与扩展</primaryFocus>
      <secondaryFocus>生产就绪、企业级稳定性</secondaryFocus>
      <justification>
        Epic 3是项目从开发阶段向生产阶段过渡的关键环节。
        性能优化直接影响用户体验和系统价值实现，是企业级应用的必要条件。
      </justification>
    </strategicAlignment>

    <criticalSuccessFactors>
      <factor>性能瓶颈的准确识别和有效解决</factor>
      <factor>高并发场景下的系统稳定性和数据一致性</factor>
      <factor>资源利用率的显著提升（CPU、内存、NPU）</factor>
      <factor>长期运行的稳定性和可靠性保证</factor>
      <factor>与Epic 1和Epic 2的完美集成</factor>
    </criticalSuccessFactors>
  </strategicContext>

  <!-- === BUSINESS CONTEXT === -->
  <businessContext>
    <businessObjective>
      优化XLeRobot NPU模型转换工具的整体性能，实现大规模、高并发、高效率的模型转换，
      满足企业级应用需求，提升用户体验和系统价值。
    </businessObjective>

    <businessValue>
      <value-proposition>
        通过性能优化，实现2-5倍的转换效率提升，支持批量并发转换，
        降低资源消耗30%+，确保生产级稳定性，为企业级用户提供卓越的转换体验。
      </value-proposition>

      <targetUsers>
        <user type="AI模型工程师">
          需要对大规模模型进行高效转换，关注转换时间和资源消耗
        </user>
        <user type="企业系统架构师">
          需要确保系统在高并发场景下的稳定性和可扩展性
        </user>
        <user type="DevOps工程师">
          需要监控和优化系统性能，确保生产环境稳定运行
        </user>
        <user type="产品经理">
          需要可衡量的性能指标和用户体验提升数据
        </user>
      </targetUsers>

      <keyMetrics>
        <metric name="转换延迟" target="&lt;5分钟" measurement="单个模型转换时间"/>
        <metric name="并发吞吐量" target="&gt;10模型/分钟" measurement="单位时间转换模型数"/>
        <metric name="资源效率" target="内存使用降低30%+" measurement="优化前后资源使用对比"/>
        <metric name="系统稳定性" target="72小时无故障" measurement="连续运行时间"/>
        <metric name="代码覆盖率" target="&gt;90%" measurement="测试覆盖代码行数/总代码行数"/>
      </keyMetrics>

      <businessRisks>
        <risk level="High" description="并发安全问题可能导致数据竞争和系统崩溃" mitigation="采用成熟设计模式，充分压力测试"/>
        <risk level="Medium" description="性能优化可能影响代码可维护性" mitigation="建立性能基线，平衡优化与可维护性"/>
        <risk level="Medium" description="性能测试难以准确模拟生产环境" mitigation="建立多层次测试体系，结合实际场景"/>
        <risk level="Low" description="Horizon X5工具链可能限制优化空间" mitigation="深入了解工具链限制，合理设计策略"/>
      </businessRisks>
    </businessValue>

    <stakeholders>
      <stakeholder role="产品经理" interest="High" influence="High">
        关注性能指标达标和用户体验提升
      </stakeholder>
      <stakeholder role="AI模型工程师" interest="High" influence="Medium">
        关注转换效率和使用便捷性
      </stakeholder>
      <stakeholder role="系统架构师" interest="High" influence="High">
        关注系统扩展性和稳定性
      </stakeholder>
      <stakeholder role="DevOps工程师" interest="Medium" influence="Medium">
        关注监控、运维和故障诊断
      </stakeholder>
      <stakeholder role="QA工程师" interest="Medium" influence="Medium">
        关注性能测试和质量保证
      </stakeholder>
    </stakeholders>
  </businessContext>

  <!-- === TECHNICAL CONTEXT === -->
  <technicalContext>
    <architecture>
      <description>
        基于Epic 1（100%完成）和Epic 2（100%完成）的完整基础设施，
        扩展性能监控、优化转换流程、增强并发处理、优化资源管理。
        严格继承Story 1.3的核心框架架构，集成所有Epic 2的功能组件。
      </description>

      <components>
        <component name="PerformanceMonitor" inheritance="BaseComponent" purpose="性能监控和分析框架"/>
        <component name="PerformanceOptimizer" purpose="性能优化引擎"/>
        <component name="ConcurrentConverter" purpose="并发转换管理器"/>
        <component name="ResourceManager" purpose="资源管理和优化"/>
        <component name="CacheManager" purpose="缓存和增量处理"/>
      </components>

      <interfaces>
        <interface name="BaseConverter" provider="Story 1.3" consumer="ConcurrentConverter"/>
        <interface name="ConfigurationManager" provider="Story 1.4" consumer="PerformanceOptimizer"/>
        <interface name="BaseConversionFlow" provider="Story 1.5" consumer="PerformanceOptimizer"/>
        <interface name="PerformanceBenchmark" provider="Story 2.8" consumer="PerformanceMonitor"/>
        <interface name="ParameterOptimizer" provider="Story 2.6" consumer="PerformanceOptimizer"/>
