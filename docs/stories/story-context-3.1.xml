      <dependencies>
        <dependency type="Mandatory" component="Epic 1 Infrastructure" version="1.0.0" description="完整基础设施 (Story 1.3-1.8)"/>
        <dependency type="Mandatory" component="Epic 2 Model Conversion" version="1.0.0" description="完整模型转换功能 (Story 2.1.1-2.10)"/>
        <dependency type="Mandatory" component="Horizon X5 BPU Toolchain" version="Latest" description="转换执行环境"/>
        <dependency type="Mandatory" component="Story 2.6 Parameter Optimization" version="1.0.0" description="参数优化算法"/>
        <dependency type="Mandatory" component="Story 2.8 Performance Benchmark" version="1.0.0" description="性能测试基础设施"/>
        <dependency type="Mandatory" component="Story 2.9 Report Generation" version="1.0.0" description="报告生成系统"/>
      </dependencies>

      <constraints>
        <constraint type="Performance" requirement="转换时间&lt;5分钟" impact="High"/>
        <constraint type="Scalability" requirement="支持10+模型并发" impact="High"/>
        <constraint type="Efficiency" requirement="内存使用降低30%+" impact="Medium"/>
        <constraint type="Stability" requirement="72小时连续运行" impact="High"/>
        <constraint type="Compatibility" requirement="与Epic 1和Epic 2 100%兼容" impact="High"/>
      </constraints>
    </architecture>

    <technologyStack>
      <layer name="Runtime" components="Python 3.10, Ubuntu 20.04, Docker"/>
      <layer name="Toolchain" components="Horizon X5 BPU Toolchain, ONNX Runtime"/>
      <layer name="Core Framework" components="XLeRobot Core Framework (Story 1.3)"/>
      <layer name="Configuration" components="ConfigurationManager (Story 1.4)"/>
      <layer name="Conversion Flows" components="BaseConversionFlow (Story 1.5)"/>
      <layer name="Model Conversion" components="Epic 2 Complete Flows (Story 2.1.1-2.10)"/>
      <layer name="Performance" components="Performance Monitor &amp; Optimizer (Story 3.1)"/>
    </technologyStack>

    <implementationDetails>
      <pattern name="Monitor" usage="PerformanceMonitor实时监控性能指标"/>
      <pattern name="Strategy" usage="PerformanceOptimizer采用不同优化策略"/>
      <pattern name="Proxy" usage="ConcurrentConverter代理和管理并发转换"/>
      <pattern name="Flyweight" usage="CacheManager共享和复用计算结果"/>
      <pattern name="Observer" usage="实时性能通知和告警"/>

      <keyAlgorithms>
        <algorithm name="PerformanceBottleneckDetection" description="性能瓶颈自动识别算法"/>
        <algorithm name="SmartTaskScheduling" description="智能任务调度算法"/>
        <algorithm name="DynamicResourceAllocation" description="动态资源分配算法"/>
        <algorithm name="IncrementalConversion" description="增量转换和缓存策略"/>
      </keyAlgorithms>

      <dataFlow>
        <flow step="1" component="PerformanceMonitor" description="初始化性能监控系统"/>
        <flow step="2" component="ResourceManager" description="分配和监控资源使用"/>
        <flow step="3" component="ConcurrentConverter" description="管理并发转换任务"/>
        <flow step="4" component="PerformanceOptimizer" description="执行性能优化策略"/>
        <flow step="5" component="BaseConversionFlow" description="执行转换流程"/>
        <flow step="6" component="CacheManager" description="缓存和增量处理"/>
        <flow step="7" component="PerformanceMonitor" description="记录和分析性能数据"/>
      </dataFlow>
    </implementationDetails>
  </technicalContext>

  <!-- === ACCEPTANCE CRITERIA DETAILS === -->
  <acceptanceCriteria>
    <criterion id="AC1" priority="High" type="Performance">
      <title>实现转换流程的性能分析框架</title>
      <description>
        建立性能指标收集体系（延迟、吞吐量、资源使用），支持实时性能监控和历史数据分析，
        提供性能瓶颈识别和诊断能力，集成Story 2.8性能基准测试系统。
      </description>

      <acceptanceTests>
        <test id="AC1-T1" name="性能指标收集测试">
          Given: 运行中的转换流程
          When: 监控系统收集性能数据
          Then: 准确记录延迟、吞吐量、CPU、内存、NPU使用率
        </test>
        <test id="AC1-T2" name="瓶颈识别测试">
          Given: 存在性能瓶颈的转换场景
          When: 自动分析性能数据
          Then: 准确识别瓶颈位置和原因
        </test>
        <test id="AC1-T3" name="基准测试集成测试">
          Given: Story 2.8性能基准测试系统
          When: 集成性能监控
          Then: 无缝对接，实时性能对比
        </test>
      </acceptanceTests>

      <dependencies>
        <dependency type="Requires" component="PerformanceMonitor" requirement="性能监控核心框架"/>
        <dependency type="Requires" component="Story 2.8" requirement="性能基准测试系统"/>
      </dependencies>
    </criterion>

    <criterion id="AC2" priority="High" type="Performance">
      <title>优化核心转换流程的执行效率</title>
      <description>
        优化Story 1.5的基础转换流程，减少不必要的计算和数据拷贝，
        实现智能任务调度和资源管理，支持增量转换和缓存机制。
      </description>

      <acceptanceTests>
        <test id="AC2-T1" name="转换效率优化测试">
          Given: 相同模型转换
          When: 执行优化前后的转换
          Then: 优化后转换时间减少20%+
        </test>
        <test id="AC2-T2" name="缓存机制测试">
          Given: 已转换过的模型
          When: 再次执行相同转换
          Then: 利用缓存，转换时间减少80%+
        </test>
        <test id="AC2-T3" name="智能调度测试">
          Given: 多个转换任务
          When: 系统自动调度
          Then: 资源利用率提升30%+，总时间减少
        </test>
      </acceptanceTests>

      <dependencies>
        <dependency type="Requires" component="PerformanceOptimizer" requirement="性能优化引擎"/>
        <dependency type="Requires" component="BaseConversionFlow" requirement="Story 1.5基础流程"/>
      </dependencies>
    </criterion>

    <criterion id="AC3" priority="High" type="Scalability">
      <title>实现可扩展的并发转换架构</title>
      <description>
        基于Epic 1的异步框架扩展并发能力，支持多模型并发转换（Batch Processing），
        实现负载均衡和任务分发机制，提供并发控制和资源隔离。
      </description>

      <acceptanceTests>
        <test id="AC3-T1" name="并发转换测试">
          Given: 10个模型同时转换
          When: 执行并发转换
          Then: 所有模型成功转换，无数据竞争
        </test>
        <test id="AC3-T2" name="负载均衡测试">
          Given: 不同复杂度的转换任务
          When: 自动分配任务
          Then: 资源合理分配，完成时间最短
        </test>
        <test id="AC3-T3" name="资源隔离测试">
          Given: 并发转换过程
          When: 监控系统资源
          Then: 任务间资源隔离，无相互干扰
        </test>
      </acceptanceTests>

      <dependencies>
        <dependency type="Requires" component="ConcurrentConverter" requirement="并发转换管理器"/>
        <dependency type="Requires" component="ResourceManager" requirement="资源管理机制"/>
      </dependencies>
    </criterion>

    <criterion id="AC4" priority="Medium" type="Efficiency">
      <title>优化内存和存储资源使用</title>
      <description>
        实现智能内存管理和回收机制，支持大模型的分块处理，
        优化临时文件和缓存管理，减少内存峰值占用30%+。
      </description>

      <acceptanceTests>
        <test id="AC4-T1" name="内存优化测试">
          Given: 大规模模型转换
          When: 执行内存优化
          Then: 内存峰值降低30%+
        </test>
        <test id="AC4-T2" name="分块处理测试">
          Given: 超大模型（&gt;1GB）
          When: 执行分块处理
          Then: 无内存溢出，正常完成转换
        </test>
        <test id="AC4-T3" name="缓存管理测试">
          Given: 频繁的转换操作
          When: 智能缓存管理
          Then: 缓存命中率&gt;80%，磁盘空间合理使用
        </test>
      </acceptanceTests>

      <dependencies>
        <dependency type="Requires" component="ResourceManager" requirement="内存和存储优化"/>
        <dependency type="Requires" component="CacheManager" requirement="智能缓存管理"/>
      </dependencies>
    </criterion>

    <criterion id="AC5" priority="Medium" type="Maintainability">
      <title>实现性能优化配置和调优系统</title>
      <description>
        集成Story 2.6参数优化系统，提供性能优化的预设配置，
        支持动态性能调优，实现性能优化的自动化推荐。
      </description>

      <acceptanceTests>
        <test id="AC5-T1" name="优化配置测试">
          Given: 系统预设的性能优化配置
          When: 应用配置
          Then: 性能提升符合配置预期
        </test>
        <test id="AC5-T2" name="动态调优测试">
          Given: 运行中的转换系统
          When: 动态调整性能参数
          Then: 实时生效，无需重启
        </test>
        <test id="AC5-T3" name="自动推荐测试">
          Given: 历史性能数据
          When: 系统分析
          Then: 提供个性化优化建议
        </test>
      </acceptanceTests>

      <dependencies>
        <dependency type="Requires" component="ParameterOptimizer" requirement="Story 2.6参数优化系统"/>
        <dependency type="Requires" component="ConfigurationManager" requirement="配置管理支持"/>
      </dependencies>
    </criterion>
  </acceptanceCriteria>

